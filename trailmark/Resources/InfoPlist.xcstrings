    "NSLocationWhenInUseUsageDescription" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PaceMark uses GPS to detect your position and trigger voice announcements at milestones."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PaceMark utilise le GPS pour détecter votre position et déclencher les annonces vocales aux jalons."
          }
        }
      }
    },
    "NSLocationAlwaysUsageDescription" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PaceMark needs background GPS to guide you by voice during your run."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PaceMark a besoin du GPS en arrière-plan pour vous guider vocalement pendant votre course."
          }
        }
      }
    },
    "NSLocationAlwaysAndWhenInUseUsageDescription" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PaceMark needs background GPS to guide you by voice during your run, even when the phone is in your pocket."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PaceMark a besoin du GPS en arrière-plan pour vous guider vocalement pendant votre course, même quand le téléphone est dans votre poche."
          }
        }
      }
    }
  },
  "version" : "1.0"
